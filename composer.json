{
    "name": "digisports/digisports",
    "description": "DigiSports - Multi-tenant Sports Management SaaS",
    "type": "project",
    "require": {
        "phpmailer/phpmailer": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "classmap": [
            "config/app.php",
            "config/database.php",
            "config/security.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "DigiSports\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit tests/ --testdox"
    },
    "config": {
        "optimize-autoloader": true
    }
}
